---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tracking — Julius Narvasa" description="Private portfolio analytics dashboard.">
  <section id="tracking" class="py-section-tight px-6" aria-labelledby="section-tracking-title">
    <div class="mx-auto max-w-narrow">
      <div data-reveal>
        <div class="flex items-start justify-between gap-4 mb-8">
          <div>
            <p class="text-h5 uppercase tracking-widest text-accent mb-3 font-mono">// tracking</p>
            <h1 id="section-tracking-title" class="text-h2 text-text mb-2">Portfolio analytics</h1>
            <p class="text-body-lg text-text-muted max-w-prose">First-party only. Counts every distinct visitor since the tracker was deployed.</p>
          </div>
          <button
            id="tracking-refresh"
            type="button"
            hidden
            class="shrink-0 rounded-md border border-border bg-bg-elevated px-3 py-2 text-body-sm text-text-muted hover:border-accent hover:text-accent transition-all duration-slow ease-out-snappy font-mono"
          >Refresh</button>
        </div>
      </div>

      <!-- KPI cards -->
      <div data-reveal data-reveal-delay="80" class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="rounded-lg border border-border bg-bg-elevated shadow-subtle p-5">
          <p class="text-body-sm uppercase tracking-wider text-text-dim font-mono">Total uniques</p>
          <p id="kpi-uniques" class="text-h2 text-accent font-mono mt-2">&mdash;</p>
        </div>
        <div class="rounded-lg border border-border bg-bg-elevated shadow-subtle p-5">
          <p class="text-body-sm uppercase tracking-wider text-text-dim font-mono">Pageviews</p>
          <p id="kpi-pageviews" class="text-h2 text-text font-mono mt-2">&mdash;</p>
        </div>
        <div class="rounded-lg border border-border bg-bg-elevated shadow-subtle p-5">
          <p class="text-body-sm uppercase tracking-wider text-text-dim font-mono">Sessions</p>
          <p id="kpi-sessions" class="text-h2 text-text font-mono mt-2">&mdash;</p>
        </div>
      </div>

      <!-- Chart: daily uniques for the last 30 days -->
      <div data-reveal data-reveal-delay="160" class="rounded-lg border border-border bg-bg-elevated shadow-subtle p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-h5 uppercase tracking-wider text-text-muted font-mono">Daily uniques &middot; last 30 days</p>
          <p id="chart-today" class="text-body-sm text-text-dim font-mono">&mdash; today</p>
        </div>
        <div id="chart-container" class="w-full h-48">
          <p class="text-text-dim text-body-sm">Loading&hellip;</p>
        </div>
      </div>

      <!-- Two-column: referrers + recent visits -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div data-reveal data-reveal-delay="240" class="rounded-lg border border-border bg-bg-elevated shadow-subtle p-6">
          <p class="text-h5 uppercase tracking-wider text-text-muted font-mono mb-4">Top referrers</p>
          <ul id="referrers" class="text-body text-text">
            <li class="text-text-dim">Loading&hellip;</li>
          </ul>
        </div>
        <div data-reveal data-reveal-delay="320" class="rounded-lg border border-border bg-bg-elevated shadow-subtle p-6">
          <p class="text-h5 uppercase tracking-wider text-text-muted font-mono mb-4">Recent visits</p>
          <ul id="recent" class="text-body text-text">
            <li class="text-text-dim">Loading&hellip;</li>
          </ul>
        </div>
      </div>

      <!-- Footer note -->
      <div data-reveal data-reveal-delay="400" class="mt-10">
        <p class="text-body-sm text-text-dim font-mono">// First-party only &middot; visitor ids are sha256(ip|ua|language) &middot; raw IPs never stored &middot; no third-party trackers.</p>
      </div>
    </div>
  </section>

  <script>
    import '../scripts/tracking-dashboard.ts';
  </script>
</Layout>
