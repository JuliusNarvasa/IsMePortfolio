---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Projects from '../components/sections/Projects.astro';
import Infrastructure from '../components/sections/Infrastructure.astro';
import AILab from '../components/sections/AILab.astro';
import Experience from '../components/sections/Experience.astro';
import Building from '../components/sections/Building.astro';
import Contact from '../components/sections/Contact.astro';
---

<Layout>
  <Nav />
  {/* Skip to content */}
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-[#0B0F14] focus:font-mono focus:shadow-accent-glow">
    Skip to content
  </a>
  <main id="main">
    <Hero />
    <Projects />
    <Infrastructure />
    <AILab />
    <Experience />
    <Building />
    <Contact />
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/reveal.ts';
</script>
