---
---

<header id="top" class="relative flex min-h-screen items-center overflow-hidden px-6 lg:px-24">
  {/* Ambient accent blob */}
  <div class="pointer-events-none absolute -right-40 -top-40 h-[800px] w-[800px] rounded-full bg-accent-glow opacity-12 blur-[800px]"></div>

  <div class="relative z-10 mx-auto flex w-full max-w-wide items-center gap-12 lg:gap-16">
    {/* Text column */}
    <div class="flex-1">
      {/* Eyebrow */}
      <p class="font-mono-sm uppercase tracking-widest text-accent mb-4" data-reveal data-reveal-delay="0">
        ~/developer/julius
      </p>

      {/* Name */}
      <h1 class="text-h1 md:text-display font-semibold text-text mb-3" data-reveal data-reveal-delay="80">
        Julius Narvasa
      </h1>

      {/* Role */}
      <p class="text-h4 text-text-muted mb-6" data-reveal data-reveal-delay="160">
        Software Developer
      </p>

      {/* Lead */}
      <p class="text-body-lg text-text-muted max-w-prose mb-6" data-reveal data-reveal-delay="240">
        I build backend systems, self-hosted AI infrastructure, and developer tooling. Currently exploring local LLMs and computer vision pipelines on AMD hardware.
      </p>

      {/* Interests */}
      <p class="font-mono-lg text-text-muted mb-8" data-reveal data-reveal-delay="320">
        <span>backend</span>
        <span class="text-accent-muted mx-2">·</span>
        <span>apis</span>
        <span class="text-accent-muted mx-2">·</span>
        <span>cloud infra</span>
        <span class="text-accent-muted mx-2">·</span>
        <span>local ai</span>
        <span class="text-accent-muted mx-2">·</span>
        <span>self-hosted systems</span>
      </p>

      {/* CTAs */}
      <div class="flex items-center gap-3" data-reveal data-reveal-delay="400">
        <a
          href="#projects"
          class="inline-flex items-center rounded-md bg-accent px-5 py-2.5 font-mono text-text shadow-subtle transition-all duration-base ease-out-snappy hover:bg-accent-hover hover:shadow-accent-glow active:scale-95"
          style="color: #0B0F14; font-weight: 500;"
        >
          View Projects →
        </a>
        <a
          href="#contact"
          class="inline-flex items-center rounded-md border border-border bg-bg-glass px-5 py-2.5 font-mono text-text backdrop-blur-glass transition-all duration-base ease-out-snappy hover:border-border-strong hover:shadow-glass active:scale-95"
        >
          Contact
        </a>
      </div>
    </div>

    {/* Slideshow column — desktop only */}
    <div class="hero-slideshow relative hidden h-[600px] w-[500px] flex-shrink-0 lg:block" data-reveal data-reveal-delay="200">
      <img src="/heroimages/1.jpg" alt="" role="button" tabindex="0" aria-label="View image full size" data-hero-slide-index="0" class="hero-slide absolute inset-0 h-full w-full rounded-lg object-cover" />
      <img src="/heroimages/2.jpg" alt="" role="button" tabindex="0" aria-label="View image full size" data-hero-slide-index="1" class="hero-slide absolute inset-0 h-full w-full rounded-lg object-cover" />
      <img src="/heroimages/3.jpg" alt="" role="button" tabindex="0" aria-label="View image full size" data-hero-slide-index="2" class="hero-slide absolute inset-0 h-full w-full rounded-lg object-cover" />
      <img src="/heroimages/4.jpg" alt="" role="button" tabindex="0" aria-label="View image full size" data-hero-slide-index="3" class="hero-slide absolute inset-0 h-full w-full rounded-lg object-cover" />
      <img src="/heroimages/5.jpg" alt="" role="button" tabindex="0" aria-label="View image full size" data-hero-slide-index="4" class="hero-slide absolute inset-0 h-full w-full rounded-lg object-cover" />
      <img src="/heroimages/6.jpg" alt="" role="button" tabindex="0" aria-label="View image full size" data-hero-slide-index="5" class="hero-slide absolute inset-0 h-full w-full rounded-lg object-cover" />

      {/* Lightbox — single instance, positioned at the end of the slideshow
          column. `position: fixed` escapes the column's stacking context so
          the lightbox covers the whole viewport regardless of placement. */}
      <div
        class="lightbox"
        role="dialog"
        aria-modal="true"
        aria-label="Image viewer"
        data-lightbox
        hidden
      >
        <div class="lightbox-backdrop" data-lightbox-backdrop></div>
        <img class="lightbox-image" alt="" data-lightbox-image tabindex="0" />
        <button type="button" class="lightbox-close" aria-label="Close" data-lightbox-close>×</button>
      </div>
    </div>
  </div>
</header>

<style>
  .hero-slideshow {
    mask-image: radial-gradient(ellipse 90% 85% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 90% 85% at 50% 50%, black 30%, transparent 100%);
  }
</style>
