---
interface Props {
  title: string;
  problem: string;
  solution: string;
  image: string;
  alt: string;
  href?: string;
}

const { title, problem, solution, image, alt, href } = Astro.props;
---

<article class="group flex h-full flex-col overflow-hidden rounded-lg border border-border bg-bg-elevated shadow-subtle transition-all duration-slow ease-out-snappy hover:-translate-y-1 hover:border-accent hover:shadow-accent-glow focus-within:border-accent focus-within:shadow-accent-glow">
  {/* Screenshot area */}
  <div class="relative overflow-hidden bg-bg" style="aspect-ratio: 3 / 2;">
    <img
      src={image}
      alt={alt}
      class="h-full w-full object-cover object-top transition-transform duration-slower ease-out-smooth group-hover:scale-[1.03]"
      loading="lazy"
    />
  </div>

  {/* Content */}
  <div class="flex flex-1 flex-col p-6">
    {/* Title */}
    <h4 class="text-h4 text-text mb-3">{title}</h4>

    {/* Problem */}
    <p class="text-body-sm text-text-muted mb-2 leading-relaxed">
      <span class="font-mono-sm text-accent mr-1.5">// problem:</span>
      {problem}
    </p>

    {/* Solution */}
    <p class="text-body-sm text-text leading-relaxed">
      <span class="font-mono-sm text-accent mr-1.5">→ fix:</span>
      {solution}
    </p>

    {/* Optional CTA */}
    {href && (
      <div class="mt-4 pt-1">
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono-sm text-accent inline-flex items-center gap-1 transition-colors duration-fast hover:text-accent-hover"
        >
          view project ↗
        </a>
      </div>
    )}
  </div>
</article>
