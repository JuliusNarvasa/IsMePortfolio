---
interface TreeNode {
  label: string;
  status?: 'online' | 'standby' | 'offline';
  description?: string;
  children?: TreeNode[];
}

interface Props {
  node: TreeNode;
  depth?: number;
  isLast?: boolean;
}

const { node, depth = 0, isLast = false } = Astro.props;

const prefix = depth === 0 ? '' : isLast ? '└─' : '├─';

const statusColor = node.status === 'online'
  ? 'bg-success'
  : node.status === 'standby'
    ? 'bg-warning'
    : node.status === 'offline'
      ? 'bg-text-dim'
      : null;

const hasChildren = node.children && node.children.length > 0;
---

<div class="tree" style={`--depth: ${depth};`}>
  <div class="tree-row">
    {depth > 0 && (
      <span class="tree-prefix">{prefix}</span>
    )}
    {statusColor && (
      <span class:list={['inline-block h-1.5 w-1.5 rounded-full flex-shrink-0', statusColor]}></span>
    )}
    <span class:list={['tree-name flex-1', depth > 0 && 'text-text-muted']}>{node.label}</span>
  </div>
  {node.description && (
    <div class="tree-description" style={`padding-left: calc(var(--depth, 0) * 16px + 16px + 24px);`}>
      {node.description}
    </div>
  )}
  {hasChildren && node.children!.map((child, i) => (
    <Astro.self node={child} depth={depth + 1} isLast={i === node.children!.length - 1} />
  ))}
</div>

<style>
  .tree-description {
    font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
    padding-top: 2px;
    padding-bottom: 6px;
    margin-left: 8px;
  }
</style>