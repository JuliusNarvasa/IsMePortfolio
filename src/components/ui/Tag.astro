---
interface Props {
  label: string;
  dot?: boolean;
  tone?: 'default' | 'accent' | 'success';
}

const { label, dot = false, tone = 'default' } = Astro.props;

const dotColor = tone === 'accent'
  ? 'bg-accent'
  : tone === 'success'
    ? 'bg-success'
    : 'bg-text-muted';
---

<span class="inline-flex items-center gap-1.5 rounded-sm border border-border bg-bg-glass px-2 py-0.5 font-mono-sm uppercase text-text-muted">
  {dot && <span class={`inline-block h-1.5 w-1.5 rounded-full ${dotColor}`}></span>}
  {label}
</span>
