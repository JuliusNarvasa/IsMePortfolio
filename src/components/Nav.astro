---
const navLinks = [
  { label: 'Beyond', href: '#beyond-the-code' },
  { label: 'Pet Projects', href: '#pet-projects' },
  { label: 'Projects', href: '#projects' },
  { label: 'Infrastructure', href: '#infrastructure' },
  { label: 'AI Lab', href: '#ai-lab' },
  { label: 'Experience', href: '#experience' },
  { label: 'Building', href: '#building' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="sticky top-0 z-50 h-14 border-b border-border bg-bg-glass-strong backdrop-blur-nav" aria-label="Primary">
  <div class="mx-auto flex h-full max-w-wide items-center justify-between px-6">
    {/* Logo — scrolls to absolute top of page */}
    <a
      href="#top"
      class="font-mono text-text transition-colors duration-fast hover:text-accent"
      data-scroll-top
    >~/julius</a>

    {/* Links — desktop only */}
    <ul class="hidden items-center gap-6 lg:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link font-mono-sm uppercase tracking-wider text-text-muted transition-colors duration-fast hover:text-text"
            data-nav-anchor={link.href}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    {/* Theme toggle — label visibility is driven by CSS using the
        `data-theme` attribute on <html> (set in Layout.astro). JS keeps
        the `aria-label` in sync and persists the choice to localStorage. */}
    <button
      type="button"
      class="font-mono-sm text-text-dim transition-colors duration-fast hover:text-text"
      data-theme-toggle
      aria-label="Toggle color theme"
    >
      <span data-theme-label-dark>[ Dark ]</span>
      <span data-theme-label-light>[ Light ]</span>
    </button>
  </div>
</nav>

<script>
  // Logo: force scroll to absolute top (y=0) instead of to #top element
  // (which sits below the sticky nav)
  const logo = document.querySelector('[data-scroll-top]');
  logo?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Active section highlight via IntersectionObserver
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('[data-nav-anchor]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach((link) => {
            const href = link.getAttribute('data-nav-anchor');
            if (href === `#${id}`) {
              link.classList.add('text-accent');
              link.classList.remove('text-text-muted');
            } else {
              link.classList.remove('text-accent');
              link.classList.add('text-text-muted');
            }
          });
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
  );

  sections.forEach((section) => observer.observe(section));

  // Theme toggle
  const themeToggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const root = document.documentElement;

  if (themeToggle) {
    const syncToggle = () => {
      const current = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      themeToggle.setAttribute('aria-label', `Switch to ${next} theme`);
    };

    // Initialise aria-label from the resolved theme.
    syncToggle();

    themeToggle.addEventListener('click', () => {
      const current = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) { /* storage blocked */ }
      syncToggle();
    });
  }
</script>
