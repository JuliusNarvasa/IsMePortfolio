---
const buildDate = '2026-06-18';
---

<footer class="border-t border-border bg-bg">
  <div class="mx-auto flex max-w-wide flex-col items-center justify-between gap-3 px-6 py-12 md:flex-row md:py-16">
    {/* Copyright */}
    <p class="font-mono-sm text-text-dim">
      &copy; 2026 Julius Narvasa
    </p>

    {/* Last updated */}
    <p class="font-mono-sm text-text-dim hidden md:block">
      last updated: {buildDate}
    </p>

    {/* Back to top */}
    <a href="#top" class="font-mono-sm text-text-dim transition-colors duration-fast hover:text-text">
      ↑ top
    </a>
  </div>
</footer>
